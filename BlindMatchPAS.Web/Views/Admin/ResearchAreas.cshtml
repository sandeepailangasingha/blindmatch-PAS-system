@model IEnumerable<BlindMatchPAS.Core.Entities.ResearchArea>

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="text-navy fw-bold">Research Areas</h2>
            <p class="text-muted">Definitions for matching projects and expertise.</p>
        </div>
        <div class="col-md-4 text-end">
            <button type="button" class="btn btn-navy" data-bs-toggle="modal" data-bs-target="#createModal">
                + New Area
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">ID</th>
                        <th class="py-3">Name</th>
                        <th class="text-end pe-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var area in Model)
                    {
                        <tr>
                            <td class="ps-4">@area.Id</td>
                            <td>@area.Name</td>
                            <td class="text-end pe-4">
                                <a asp-action="DeleteResearchArea" asp-route-id="@area.Id" 
                                   class="btn btn-sm btn-outline-danger" 
                                   onclick="return confirm('Are you sure?')">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateResearchArea" method="post">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold">Add Research Area</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Area Name</label>
                        <input type="text" name="name" class="form-control" required placeholder="e.g., Artificial Intelligence">
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Area</button>
                </div>
            </div>
        </form>
    </div>
</div>

<style>
    .text-navy { color: #001f3f; }
    .btn-navy { background-color: #001f3f; color: white; }
    .btn-navy:hover { background-color: #003366; color: white; }
</style>
