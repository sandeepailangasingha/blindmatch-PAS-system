@model IEnumerable<BlindMatchPAS.Core.Entities.ApplicationUser>
@using Microsoft.AspNetCore.Identity
@inject UserManager<BlindMatchPAS.Core.Entities.ApplicationUser> UserManager

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-navy fw-bold">User Management</h2>
            <p class="text-muted">Promote to Admin or delete accounts.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">User</th>
                        <th class="py-3">Current Roles</th>
                        <th class="text-end pe-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = await UserManager.GetRolesAsync(user);
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@user.FullName</div>
                                <div class="small text-muted">@user.Email</div>
                            </td>
                            <td>
                                @foreach (var role in roles)
                                {
                                    <span class="badge @(role == "Admin" ? "bg-danger" : (role == "Supervisor" ? "bg-info" : "bg-success")) me-1">
                                        @role
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                @if (!roles.Contains("Admin"))
                                {
                                    <form asp-action="PromoteToAdmin" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-primary me-2">Promote to Admin</button>
                                    </form>
                                }
                                <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Account will be permanently deleted. Continue?')">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .text-navy { color: #001f3f; }
</style>
