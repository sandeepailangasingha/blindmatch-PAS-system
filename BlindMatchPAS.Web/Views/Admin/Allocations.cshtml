@model IEnumerable<BlindMatchPAS.Core.Entities.MatchRecord>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-navy fw-bold">Allocation Oversight</h2>
            <p class="text-muted">Review and manage current project-supervisor matches.</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4 py-3">Student / Project</th>
                        <th class="py-3">Supervisor</th>
                        <th class="py-3">Matched Date</th>
                        <th class="text-end pe-4 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var match in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@match.ProjectProposal?.Title</div>
                                <div class="small text-muted">@match.ProjectProposal?.Student?.FullName</div>
                            </td>
                            <td>
                                <div class="fw-bold">@match.Supervisor?.FullName</div>
                                <div class="small text-muted">@match.Supervisor?.Email</div>
                            </td>
                            <td>@(match.MatchedDate?.ToString("yyyy-MM-dd HH:mm") ?? "N/A")</td>
                            <td class="text-end pe-4">
                                <form asp-action="RemoveMatch" method="post" class="d-inline" onsubmit="return confirm('Reset this match and return proposal to Pending? This will be logged.')">
                                    <input type="hidden" name="matchId" value="@match.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove Match</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">No matches found in the system.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .text-navy { color: #001f3f; }
</style>
