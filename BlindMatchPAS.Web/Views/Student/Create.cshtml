@model BlindMatchPAS.Core.Entities.ProjectProposal
@{
    ViewData["Title"] = "Submit Proposal";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f0f4f8;
    }

    .page-header {
        background: linear-gradient(145deg, #0a1e3d 0%, #0f254c 100%);
        border-radius: 20px;
        padding: 30px 35px;
        color: white;
        margin-bottom: 30px;
        border-bottom: 5px solid #8DC63F;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(141,198,63,0.08);
            border-radius: 50%;
            top: -60px;
            right: -40px;
        }

    .form-card {
        background: white;
        border-radius: 20px;
        border: none;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .form-label {
        font-size: 0.88rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }

    .ultra-input {
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 0.95rem;
        background: #f8fafc;
        transition: all 0.3s ease;
    }

        .ultra-input:focus {
            border-color: #8DC63F;
            background: white;
            box-shadow: 0 0 0 4px rgba(141,198,63,0.12);
            outline: none;
        }

    .btn-submit {
        background: linear-gradient(135deg, #8DC63F, #79b535);
        color: #0f254c;
        font-weight: 800;
        border: none;
        border-radius: 12px;
        padding: 13px 28px;
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(141,198,63,0.4);
            color: white;
        }

    .btn-cancel {
        background: #f3f4f6;
        color: #374151;
        font-weight: 600;
        border: none;
        border-radius: 12px;
        padding: 13px 28px;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            background: #e5e7eb;
            transform: translateY(-2px);
        }

    .tip-box {
        background: #f0fdf4;
        border-left: 4px solid #8DC63F;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 0.83rem;
        color: #374151;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Header -->
            <div class="page-header">
                <div class="d-flex align-items-center gap-3">
                    <div style="background:#8DC63F;width:46px;height:46px;
                         border-radius:12px;display:flex;align-items:center;
                         justify-content:center;flex-shrink:0;">
                        <i class="bi bi-file-earmark-plus-fill text-dark fs-5"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0">Submit New Proposal</h4>
                        <p class="mb-0 mt-1" style="color:#94a3b8;font-size:0.83rem;">
                            Fill in your project details carefully
                        </p>
                    </div>
                </div>
            </div>

            <!-- Form Card -->
            <div class="form-card p-4 p-sm-5">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger mb-4" role="alert"></div>

                    <!-- Title -->
                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">
                            <i class="bi bi-card-heading me-2" style="color:#8DC63F;"></i>
                            Project Title
                        </label>
                        <input asp-for="Title" class="form-control ultra-input"
                               placeholder="Enter a clear and descriptive project title" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <!-- Abstract -->
                    <div class="mb-4">
                        <label asp-for="Abstract" class="form-label">
                            <i class="bi bi-text-paragraph me-2" style="color:#8DC63F;"></i>
                            Abstract
                        </label>
                        <textarea asp-for="Abstract" class="form-control ultra-input"
                                  rows="5"
                                  placeholder="Describe your project idea, objectives and expected outcomes...">
                        </textarea>
                        <span asp-validation-for="Abstract" class="text-danger small"></span>
                        <div class="tip-box mt-2">
                            <i class="bi bi-lightbulb me-2" style="color:#8DC63F;"></i>
                            Minimum 50 characters. Be specific about your project goals.
                        </div>
                    </div>

                    <!-- Technical Stack -->
                    <div class="mb-4">
                        <label asp-for="TechnicalStack" class="form-label">
                            <i class="bi bi-code-slash me-2" style="color:#8DC63F;"></i>
                            Technical Stack
                        </label>
                        <input asp-for="TechnicalStack" class="form-control ultra-input"
                               placeholder="e.g. ASP.NET Core, SQL Server, React, Azure" />
                        <span asp-validation-for="TechnicalStack" class="text-danger small"></span>
                    </div>

                    <!-- Research Area -->
                    <div class="mb-5">
                        <label asp-for="ResearchAreaId" class="form-label">
                            <i class="bi bi-tags me-2" style="color:#8DC63F;"></i>
                            Research Area
                        </label>
                        <select asp-for="ResearchAreaId" asp-items="ViewBag.ResearchAreas"
                                class="form-select ultra-input">
                            <option value="">-- Select Research Area --</option>
                        </select>
                        <span asp-validation-for="ResearchAreaId" class="text-danger small"></span>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-submit">
                            <i class="bi bi-send me-2"></i>Submit Proposal
                        </button>
                        <a asp-action="Index" class="btn btn-cancel">
                            <i class="bi bi-x-lg me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}