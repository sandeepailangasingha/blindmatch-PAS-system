@model IEnumerable<BlindMatchPAS.Core.Entities.ProjectProposal>
@{
    ViewData["Title"] = "My Proposals";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold" style="color:#0f254c;">My Project Proposals</h2>
        <a asp-action="Create" class="btn"
           style="background:#8DC63F;color:#0f254c;font-weight:700;border-radius:10px;">
            + New Proposal
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <p class="text-muted">No proposals yet. Click "New Proposal" to get started!</p>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            <div class="card mb-3" style="border-radius:12px;border:none;
                         box-shadow:0 4px 15px rgba(0,0,0,0.08);">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between">
                        <h5 class="fw-bold" style="color:#0f254c;">@item.Title</h5>
                        <span class="badge" style="background:
                                    @(item.Status == "Matched" ? "#8DC63F" :
                                                                          item.Status == "Under Review" ? "#ffc107" : "#6c757d");
                            color:white;border-radius:8px;padding:8px 12px;">
                    @item.Status
                </span>
            </div>
            <p class="text-muted mt-2">@item.ResearchArea?.Name</p>
            <div class="mt-3">
                <a asp-action="Details" asp-route-id="@item.Id"
                   class="btn btn-sm me-2"
                   style="background:#0f254c;color:white;border-radius:8px;">
                    View
                </a>
                @if (item.Status != "Matched")
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id"
                               class="btn btn-sm me-2"
                               style="background:#e9ecef;color:#0f254c;border-radius:8px;">
                                Edit
                            </a>
                            <form asp-action="Withdraw" asp-route-id="@item.Id"
                                  method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm"
                                        style="background:#dc3545;color:white;border-radius:8px;">
                                    Withdraw
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>