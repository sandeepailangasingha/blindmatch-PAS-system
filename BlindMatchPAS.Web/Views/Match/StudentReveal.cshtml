@model BlindMatchPAS.Core.Entities.MatchRecord
@{
    ViewData["Title"] = "Your Supervisor Revealed!";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f0f4f8;
    }

    .reveal-banner {
        background: linear-gradient(145deg, #0a1e3d 0%, #0f254c 100%);
        border-radius: 20px;
        padding: 30px 35px;
        color: white;
        margin-bottom: 30px;
        border-bottom: 5px solid #8DC63F;
        text-align: center;
    }

    .reveal-card {
        background: white;
        border-radius: 20px;
        border: none;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        overflow: hidden;
    }

    .reveal-header {
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border-bottom: 3px solid #8DC63F;
        padding: 20px 24px;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 0;
        border-bottom: 1px solid #f3f4f6;
    }

        .info-item:last-child {
            border: none;
        }

    .info-icon {
        width: 38px;
        height: 38px;
        background: #f0fdf4;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .btn-back {
        background: #0f254c;
        color: white;
        font-weight: 600;
        border: none;
        border-radius: 10px;
        padding: 10px 24px;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background: #1a3a6b;
            color: white;
            transform: translateY(-2px);
        }
</style>

<div class="container py-4">

    <!-- Banner -->
    <div class="reveal-banner">
        <div style="font-size:3rem;">🎓</div>
        <h3 class="fw-bold mt-2">Your Supervisor Has Been Revealed!</h3>
        <p style="color:#94a3b8;">
            Matched on @Model.MatchedDate?.ToString("dd MMM yyyy")
        </p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="reveal-card">
                <div class="reveal-header">
                    <h5 class="fw-bold mb-0" style="color:#166534;">
                        <i class="bi bi-person-workspace me-2"></i>
                        Your Supervisor Details
                    </h5>
                    <p class="mb-0 mt-1 text-muted small">
                        You can now contact your supervisor directly
                    </p>
                </div>
                <div class="p-4">
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-person" style="color:#8DC63F;"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold">Full Name</small>
                            <p class="mb-0 fw-bold" style="color:#0f254c;">
                                @Model.Supervisor?.FullName
                            </p>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-envelope" style="color:#8DC63F;"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold">Email</small>
                            <p class="mb-0 fw-bold" style="color:#0f254c;">
                                @Model.Supervisor?.Email
                            </p>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-tags" style="color:#8DC63F;"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold">Research Area</small>
                            <p class="mb-0 fw-bold" style="color:#0f254c;">
                                @Model.Supervisor?.ResearchArea
                            </p>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="bi bi-file-text" style="color:#8DC63F;"></i>
                        </div>
                        <div>
                            <small class="text-muted fw-bold">Project Title</small>
                            <p class="mb-0 fw-bold" style="color:#0f254c;">
                                @Model.ProjectProposal?.Title
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <a asp-controller="Student" asp-action="Index" class="btn btn-back">
                    <i class="bi bi-arrow-left me-2"></i>Back to My Proposals
                </a>
            </div>
        </div>
    </div>
</div>