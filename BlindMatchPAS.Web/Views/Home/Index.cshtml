@{
    ViewData["Title"] = "Home Page";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f0f4f8;
    }

    .hero-section {
        background: linear-gradient(145deg, #0a1e3d 0%, #0f254c 100%);
        border-radius: 20px;
        padding: 60px 40px;
        color: white;
        text-align: center;
        position: relative;
        overflow: hidden;
        border-bottom: 5px solid #8DC63F;
        margin-bottom: 40px;
    }

        .hero-section::before {
            content: '';
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(141,198,63,0.08);
            border-radius: 50%;
            top: -100px;
            right: -100px;
        }

        .hero-section::after {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(255,255,255,0.04);
            border-radius: 50%;
            bottom: -60px;
            left: -60px;
        }

    .hero-badge {
        background: rgba(141,198,63,0.2);
        border: 1px solid rgba(141,198,63,0.4);
        color: #8DC63F;
        border-radius: 20px;
        padding: 6px 16px;
        font-size: 0.82rem;
        font-weight: 700;
        display: inline-block;
        margin-bottom: 20px;
    }

    .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 16px;
    }

        .hero-title span {
            color: #8DC63F;
        }

    .btn-dashboard {
        background: linear-gradient(135deg, #8DC63F, #79b535);
        color: #0f254c;
        font-weight: 800;
        border: none;
        border-radius: 50px;
        padding: 14px 36px;
        font-size: 1rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        margin: 8px;
    }

        .btn-dashboard:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px rgba(141,198,63,0.4);
            color: white;
        }

    .btn-signin {
        background: rgba(255,255,255,0.1);
        color: white;
        font-weight: 700;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50px;
        padding: 14px 36px;
        font-size: 1rem;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        margin: 8px;
    }

        .btn-signin:hover {
            background: rgba(255,255,255,0.2);
            color: white;
            transform: translateY(-3px);
        }

    .feature-card {
        background: white;
        border-radius: 16px;
        padding: 28px;
        text-align: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        height: 100%;
    }

        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.1);
        }

    .feature-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #8DC63F, #79b535);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 16px;
        font-size: 1.5rem;
        color: #0f254c;
    }
</style>

<div class="container py-4">

    <!-- Hero -->
    <div class="hero-section">
        <div class="hero-badge">
            <i class="bi bi-shield-check me-1"></i>
            NSBM Official Project Allocation
        </div>
        <h1 class="hero-title">
            Fair & Unbiased<br>
            <span>Blind-Match</span> PAS
        </h1>
        <p class="mb-4" style="color:#94a3b8;font-size:1.05rem;max-width:600px;margin:0 auto 24px;">
            Connecting students' innovative project proposals with the expertise
            of academic supervisors, completely anonymously to ensure 100%
            fairness and merit-based selection.
        </p>

        @if (User.Identity!.IsAuthenticated)
        {
            <a asp-controller="Home" asp-action="Dashboard" class="btn-dashboard">
                <i class="bi bi-grid me-2"></i>Go to Dashboard
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn-dashboard">
                <i class="bi bi-rocket me-2"></i>Get Started Now
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn-signin">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </a>
        }
    </div>

    <!-- Feature Cards -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-eye-slash"></i>
                </div>
                <h5 class="fw-bold" style="color:#0f254c;">Blind Review</h5>
                <p class="text-muted small">
                    Supervisors review projects without knowing student identities,
                    ensuring fair selection based on merit.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-person-check"></i>
                </div>
                <h5 class="fw-bold" style="color:#0f254c;">Smart Matching</h5>
                <p class="text-muted small">
                    Projects are matched with supervisors based on research area
                    alignment and expertise.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon">
                    <i class="bi bi-unlock"></i>
                </div>
                <h5 class="fw-bold" style="color:#0f254c;">Identity Reveal</h5>
                <p class="text-muted small">
                    Once a match is confirmed, both parties can see each other's
                    details for formal collaboration.
                </p>
            </div>
        </div>
    </div>
</div>