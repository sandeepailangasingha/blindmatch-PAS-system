@model IEnumerable<dynamic>
@{
    ViewData["Title"] = "Supervisor Dashboard";
    var researchAreas = ViewBag.ResearchAreas as List<BlindMatchPAS.Core.Entities.ResearchArea>
        ?? new List<BlindMatchPAS.Core.Entities.ResearchArea>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f0f4f8;
    }

    .page-header {
        background: linear-gradient(145deg, #0a1e3d 0%, #0f254c 100%);
        border-radius: 20px;
        padding: 30px 35px;
        color: white;
        margin-bottom: 30px;
        border-bottom: 5px solid #8DC63F;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(141,198,63,0.08);
            border-radius: 50%;
            top: -60px;
            right: -40px;
        }

    .filter-bar {
        background: white;
        border-radius: 16px;
        padding: 20px 24px;
        margin-bottom: 24px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    }

    .proposal-card {
        background: white;
        border-radius: 16px;
        border: none;
        border-left: 5px solid #8DC63F;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        margin-bottom: 16px;
    }

        .proposal-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

    .blind-badge {
        background: #f0fdf4;
        color: #166534;
        border-radius: 20px;
        padding: 5px 12px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .tech-tag {
        background: #f3f4f6;
        color: #374151;
        border-radius: 8px;
        padding: 4px 10px;
        font-size: 0.78rem;
        font-weight: 600;
        display: inline-block;
        margin: 2px;
    }

    .btn-interest {
        background: linear-gradient(135deg, #8DC63F, #79b535);
        color: #0f254c;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        padding: 9px 20px;
        transition: all 0.3s ease;
        font-size: 0.88rem;
    }

        .btn-interest:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(141,198,63,0.4);
            color: white;
        }

    .filter-select {
        border: 2px solid #e5e7eb;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.9rem;
        transition: all 0.3s ease;
    }

        .filter-select:focus {
            border-color: #8DC63F;
            box-shadow: 0 0 0 4px rgba(141,198,63,0.12);
            outline: none;
        }
</style>

<div class="container py-4">

    <!-- Header -->
    <div class="page-header">
        <div class="d-flex align-items-center gap-3">
            <div style="background:#8DC63F;width:46px;height:46px;
                 border-radius:12px;display:flex;align-items:center;
                 justify-content:center;flex-shrink:0;">
                <i class="bi bi-eye-slash-fill text-dark fs-5"></i>
            </div>
            <div>
                <h4 class="fw-bold mb-0">Blind Review Dashboard</h4>
                <p class="mb-0 mt-1" style="color:#94a3b8;font-size:0.83rem;">
                    Student identities are hidden. Review projects by merit only.
                </p>
            </div>
        </div>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
        <form method="get" asp-action="Index"
              class="d-flex align-items-center gap-3 flex-wrap">
            <label class="fw-bold text-muted small me-2">
                <i class="bi bi-funnel me-1"></i>Filter by Research Area:
            </label>
            <select name="researchAreaId" class="form-select filter-select"
                    style="max-width:250px;">
                <option value="">All Areas</option>
                @foreach (var area in researchAreas)
                {
                    <option value="@area.Id"
                            selected="@(ViewBag.SelectedArea != null &&
                                                               ViewBag.SelectedArea == area.Id)">
                    @area.Name
                </option>
                                }
            </select>
            <button type="submit" class="btn btn-interest">
                <i class="bi bi-search me-1"></i>Filter
            </button>
        </form>
    </div>

    <!-- Proposals -->
    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-inbox" style="font-size:3rem;color:#d1d5db;"></i>
            <h5 class="mt-3 fw-bold" style="color:#374151;">
                No Proposals Available
            </h5>
            <p class="text-muted">
                No proposals match your selected research area.
            </p>
        </div>
    }
    else
    {
        foreach (var item in Model)
        {
            <div class="proposal-card">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="fw-bold mb-1" style="color:#0f254c;">
                                @item.Title
                            </h5>
                            <span class="blind-badge">
                                <i class="bi bi-shield-check me-1"></i>
                                Anonymous Submission
                            </span>
                        </div>
                        <span class="badge"
                              style="background:#e0f2fe;color:#0369a1;
                                      border-radius:8px;padding:6px 12px;
                                      font-size:0.78rem;">
                            @item.ResearchAreaName
                        </span>
                    </div>

                    <p class="text-muted mb-3" style="font-size:0.9rem;
                               overflow:hidden;display:-webkit-box;
                               -webkit-line-clamp:3;-webkit-box-orient:vertical;">
                        @item.Abstract
                    </p>

                    <div class="mb-3">
                        <small class="fw-bold text-muted">Tech Stack:</small>
                        <div class="mt-1">
                            @foreach (var tech in ((string)item.TechnicalStack)
                                                .Split(',',
                                                StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="tech-tag">@tech.Trim()</span>
                            }
                        </div>
                    </div>

                    <form asp-action="ExpressInterest" method="post"
                          style="display:inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="proposalId" value="@item.Id" />
                        <button type="submit" class="btn btn-interest">
                            <i class="bi bi-hand-thumbs-up me-2"></i>
                            Express Interest
                        </button>
                    </form>
                </div>
            </div>
        }
    }
</div>