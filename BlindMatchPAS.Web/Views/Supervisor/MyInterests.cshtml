@model IEnumerable<BlindMatchPAS.Core.Entities.MatchRecord>
@{
    ViewData["Title"] = "My Interests";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f0f4f8;
    }

    .page-header {
        background: linear-gradient(145deg, #0a1e3d 0%, #0f254c 100%);
        border-radius: 20px;
        padding: 30px 35px;
        color: white;
        margin-bottom: 30px;
        border-bottom: 5px solid #8DC63F;
        position: relative;
        overflow: hidden;
    }

        .page-header::before {
            content: '';
            position: absolute;
            width: 200px;
            height: 200px;
            background: rgba(141,198,63,0.08);
            border-radius: 50%;
            top: -60px;
            right: -40px;
        }

    .interest-card {
        background: white;
        border-radius: 16px;
        border: none;
        border-left: 5px solid #8DC63F;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        margin-bottom: 16px;
    }

        .interest-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

        .interest-card.confirmed {
            border-left-color: #8DC63F;
        }

        .interest-card.pending {
            border-left-color: #ffc107;
        }

    .btn-confirm {
        background: linear-gradient(135deg, #8DC63F, #79b535);
        color: #0f254c;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        padding: 9px 20px;
        transition: all 0.3s ease;
    }

        .btn-confirm:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(141,198,63,0.4);
            color: white;
        }

    .btn-view {
        background: #0f254c;
        color: white;
        font-weight: 600;
        border: none;
        border-radius: 10px;
        padding: 9px 20px;
        transition: all 0.3s ease;
    }

        .btn-view:hover {
            background: #1a3a6b;
            color: white;
            transform: translateY(-2px);
        }
</style>

<div class="container py-4">

    <!-- Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <div style="background:#8DC63F;width:46px;height:46px;
                     border-radius:12px;display:flex;align-items:center;
                     justify-content:center;flex-shrink:0;">
                    <i class="bi bi-bookmark-star-fill text-dark fs-5"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-0">My Interests</h4>
                    <p class="mb-0 mt-1" style="color:#94a3b8;font-size:0.83rem;">
                        Projects you have expressed interest in
                    </p>
                </div>
            </div>
            <a asp-action="Index" class="btn"
               style="background:#8DC63F;color:#0f254c;
               font-weight:700;border-radius:10px;">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm">
            <i class="bi bi-bookmark" style="font-size:3rem;color:#d1d5db;"></i>
            <h5 class="mt-3 fw-bold" style="color:#374151;">No Interests Yet</h5>
            <p class="text-muted">
                Go to the dashboard and express interest in projects!
            </p>
            <a asp-action="Index" class="btn btn-confirm mt-2">
                Browse Projects
            </a>
        </div>
    }
    else
    {
        foreach (var match in Model)
        {
            <div class="interest-card @(match.IsConfirmed ? "confirmed" : "pending")">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h5 class="fw-bold mb-1" style="color:#0f254c;">
                                @match.ProjectProposal?.Title
                            </h5>
                            <span class="badge"
                                  style="background:#e0f2fe;color:#0369a1;
                                          border-radius:8px;padding:5px 12px;">
                                @match.ProjectProposal?.ResearchArea?.Name
                            </span>
                        </div>
                        @if (match.IsConfirmed)
                        {
                            <span class="badge"
                                  style="background:#f0fdf4;color:#166534;
                                              border-radius:8px;padding:8px 14px;
                                              font-weight:700;">
                                <i class="bi bi-check-circle me-1"></i>Matched!
                            </span>
                        }
                        else
                        {
                            <span class="badge"
                                  style="background:#fffbeb;color:#92400e;
                                              border-radius:8px;padding:8px 14px;
                                              font-weight:700;">
                                <i class="bi bi-clock me-1"></i>Pending
                            </span>
                        }
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        @if (!match.IsConfirmed)
                        {
                            <form asp-action="ConfirmMatch" method="post"
                                  style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="matchId" value="@match.Id" />
                                <button type="submit" class="btn btn-confirm">
                                    <i class="bi bi-check-lg me-2"></i>Confirm Match
                                </button>
                            </form>
                        }
                        else
                        {
                            <a asp-action="MatchDetails" asp-route-matchId="@match.Id"
                               class="btn btn-view">
                                <i class="bi bi-person-check me-2"></i>View Student Details
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>