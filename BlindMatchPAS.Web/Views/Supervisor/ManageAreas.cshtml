@model IEnumerable<BlindMatchPAS.Core.Entities.ResearchArea>
@{
    ViewData["Title"] = "Manage My Research Areas";
    var myAreaIds = ViewBag.MyAreaIds as List<int> ?? new List<int>();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f0f4f8;
    }

    .page-header {
        background: linear-gradient(145deg, #0a1e3d 0%, #0f254c 100%);
        border-radius: 20px;
        padding: 30px 35px;
        color: white;
        margin-bottom: 30px;
        border-bottom: 5px solid #8DC63F;
        position: relative;
        overflow: hidden;
    }

    .area-card {
        background: white;
        border-radius: 16px;
        border: none;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        margin-bottom: 12px;
        padding: 16px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .area-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }

        .area-card.selected {
            border-left: 5px solid #8DC63F;
        }

    .btn-add {
        background: linear-gradient(135deg, #8DC63F, #79b535);
        color: #0f254c;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        padding: 8px 18px;
        transition: all 0.3s ease;
        font-size: 0.88rem;
    }

        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(141,198,63,0.4);
            color: white;
        }

    .btn-remove {
        background: #fee2e2;
        color: #dc2626;
        font-weight: 700;
        border: none;
        border-radius: 10px;
        padding: 8px 18px;
        transition: all 0.3s ease;
        font-size: 0.88rem;
    }

        .btn-remove:hover {
            background: #fecaca;
            transform: translateY(-2px);
        }
</style>

<div class="container py-4">

    <!-- Header -->
    <div class="page-header">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <div style="background:#8DC63F;width:46px;height:46px;
                     border-radius:12px;display:flex;align-items:center;
                     justify-content:center;flex-shrink:0;">
                    <i class="bi bi-tags-fill text-dark fs-5"></i>
                </div>
                <div>
                    <h4 class="fw-bold mb-0">My Research Areas</h4>
                    <p class="mb-0 mt-1" style="color:#94a3b8;font-size:0.83rem;">
                        Select areas that match your expertise
                    </p>
                </div>
            </div>
            <a asp-action="Index" class="btn"
               style="background:#8DC63F;color:#0f254c;
               font-weight:700;border-radius:10px;">
                <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Areas List -->
    @foreach (var area in Model)
    {
        var isSelected = myAreaIds.Contains(area.Id);
        <div class="area-card @(isSelected ? "selected" : "")">
            <div class="d-flex align-items-center gap-3">
                @if (isSelected)
                {
                    <i class="bi bi-check-circle-fill" style="color:#8DC63F;font-size:1.3rem;"></i>
                }
                else
                {
                    <i class="bi bi-circle" style="color:#d1d5db;font-size:1.3rem;"></i>
                }
                <span class="fw-bold" style="color:#0f254c;">@area.Name</span>
            </div>

            @if (isSelected)
            {
                <form asp-action="RemoveArea" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="researchAreaId" value="@area.Id" />
                    <button type="submit" class="btn btn-remove">
                        <i class="bi bi-dash-circle me-1"></i>Remove
                    </button>
                </form>
            }
            else
            {
                <form asp-action="AddArea" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="researchAreaId" value="@area.Id" />
                    <button type="submit" class="btn btn-add">
                        <i class="bi bi-plus-circle me-1"></i>Add
                    </button>
                </form>
            }
        </div>
    }

</div>